# ============================================
# Madcap Tees — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local or actual secrets to git

# ADMIN (MVP — simple password, replace with Supabase Auth in Phase 2)
# Default: changeme123 — CHANGE THIS IN PRODUCTION!
VITE_ADMIN_PASSWORD=changeme123

# SUPABASE (Required for production)
# Get these from https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# STRIPE (For Phase 2 - Payment Processing)
# Get these from https://dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SITE CONFIGURATION
# Used for Open Graph images and canonical URLs in production
VITE_SITE_URL=https://madcaptees.com

# EMAIL SERVICE (For Phase 2 - Order Confirmations)
# Optional: Resend or SendGrid for transactional emails
VITE_EMAIL_SERVICE=resend
RESEND_API_KEY=re_...

# PRINT-ON-DEMAND (For Phase 2 - Order Fulfillment)
# Optional: Printful or Printify for POD integration
VITE_POD_PROVIDER=printful
PRINTFUL_API_KEY=...

# LOCAL DEVELOPMENT
# Set to 'development' or 'production'
VITE_ENV=development
